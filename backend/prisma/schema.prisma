generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  apps App[]
}

model App {
  id          String   @id @default(cuid())
  name        String
  appStoreUrl String?
  iconUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  reports         Report[]
  integrations    Integration[]
  adSpends        AdSpendDaily[]
  geoReports      GeoReport[]
  campaignReports CampaignReport[]

  @@index([ownerId])
}

enum IntegrationType {
  APPHUD
  APPSFLYER
}

model Integration {
  id                   String          @id @default(cuid())
  appId                String
  app                  App             @relation(fields: [appId], references: [id], onDelete: Cascade)
  type                 IntegrationType
  credentialsEncrypted String
  settings             Json            @default("{}")
  isEnabled            Boolean         @default(true)
  lastSyncAt           DateTime?
  lastSyncError        String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([appId, type])
  @@index([appId])
}

model AdSpendDaily {
  id        String   @id @default(cuid())
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  date      DateTime
  source    String
  campaign  String   @default("")
  spend     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appId, date, source, campaign])
  @@index([appId, date])
}

model GeoReport {
  id                       String   @id @default(cuid())
  appId                    String
  app                      App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  date                     DateTime
  country                  String

  trialStartedDay          Int      @default(0)
  subscriptionStartedDay   Int      @default(0)
  subscriptionCancelledDay Int      @default(0)
  activeSubscriptionsDay   Int      @default(0)
  netGrowthDay             Int      @default(0)
  revenueDay               Decimal  @db.Decimal(10, 2) @default(0)
  refundsDay               Decimal  @db.Decimal(10, 2) @default(0)
  purchasesDay             Int      @default(0)
  purchasesRevenueDay      Decimal  @db.Decimal(10, 2) @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appId, date, country])
  @@index([appId, date])
  @@index([appId, country])
}

model TelegramEventLog {
  id           String   @id @default(cuid())
  appId        String
  messageId    String   // Telegram channel message_id (unique per channel post)
  eventType    String   // trial | sub | cancel | renew | refund | billing_issue | purchase
  apphudUserId String?  // User ID parsed from Apphud notification (for reference)
  createdAt    DateTime @default(now())

  @@unique([appId, messageId])
  @@index([appId, createdAt])
}

model Report {
  id   String   @id @default(cuid())
  appId String
  app  App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  date DateTime
  geo  String   @default("ALL")

  installTotal                Int
  paywallShownTotal           Int
  trialStartedTotal           Int
  subscriptionStartedTotal    Int
  subscriptionCancelledTotal  Int
  paymentFailedTotal          Int
  subscriptionActiveTotal     Int

  installDay                  Int
  paywallShownDay             Int
  trialStartedDay             Int
  subscriptionStartedDay      Int
  subscriptionCancelledDay    Int
  paymentFailedDay            Int
  subscriptionActiveDay       Int

  netGrowthDay Int

  adSpend    Decimal @db.Decimal(10, 2)
  revenueDay Decimal @db.Decimal(10, 2)
  refundsDay Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appId, date, geo])
  @@index([appId, geo, date(sort: Desc)])
}

model CampaignReport {
  id            String   @id @default(cuid())
  appId         String
  app           App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  date          DateTime
  mediaSource   String
  campaign      String   @default("")
  country       String   @default("")
  installs      Int      @default(0)
  trials        Int      @default(0)
  subscriptions Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([appId, date, mediaSource, campaign, country])
  @@index([appId, date])
  @@index([appId, mediaSource])
  @@index([appId, country])
}
